@model List<Group16_iPERMITAPP.Models.PermitRequestViewModel>
@{
    ViewBag.Title = "EO Dashboard";
}

<!DOCTYPE html>
<html>
<head>
    <title>EO Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f0f4f8;
        }

        .navbar {
            background-color: #2c7a4b;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar h1 {
                color: white;
                font-size: 22px;
            }

            .navbar a {
                color: white;
                text-decoration: none;
                font-size: 14px;
                background-color: #245f3c;
                padding: 8px 16px;
                border-radius: 6px;
            }

                .navbar a:hover {
                    background-color: #1a4a2e;
                }

        .container {
            padding: 40px;
        }

        .welcome {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

            .welcome h2 {
                color: #2c7a4b;
                margin-bottom: 10px;
            }

            .welcome p {
                color: #888;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            margin-bottom: 20px;
        }

        th, td {
            padding: 12px 20px; /* more space inside cells */
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        thead th {
            background-color: #2c7a4b;
            color: white;
            font-weight: bold;
        }

        tbody tr:hover {
            background-color: #f1f1f1; /* optional: row highlight on hover */
        }
    </style>


</head>

<body>
    <div class="navbar">
        <h1>🌿 iPERMIT - EO Dashboard</h1>
    </div>

    <div class="container">
        <div class="welcome">
            <h2>Welcome, @Session["UserId"]!</h2>
            <p>You are logged in as an Environmental Officer.</p>
        </div>

        <h3 class="section-title">Submitted Permit Requests</h3>

        @if (Model != null && Model.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Request No</th>
                        <th>RE ID</th>
                        <th>Permit ID</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model)
                    {
                        <tr>
                            <td>@request.RequestNo</td>
                            <td>
                                @request.REId
                                @if (!string.IsNullOrEmpty(request.OrganizationName) || !string.IsNullOrEmpty(request.ContactPersonName) || !string.IsNullOrEmpty(request.REEmail))
                                {
                                    <div class="re-details">
                                        @(!string.IsNullOrEmpty(request.OrganizationName) ? request.OrganizationName + (string.IsNullOrEmpty(request.ContactPersonName) ? "" : " - ") : "")
                                        @(!string.IsNullOrEmpty(request.ContactPersonName) ? request.ContactPersonName : "")
                                        <br />
                                        @if (!string.IsNullOrEmpty(request.REEmail))
                                        {
                                            <a href="mailto:@request.REEmail">@request.REEmail</a>
                                        }
                                    </div>
                                }
                            </td>
                            <td>@request.PermitID</td>
                            <td>@request.Status</td>
                            <td>@request.ActivityDescription</td>
                            <td>
                                <a class="btn-view" href="@Url.Action("Details", "EODashboard", new { id = request.RequestNo })">View/Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="muted">No permit requests submitted yet.</div>
        }

        <h3 class="section-title">Registered Entities (RE)</h3>

        @{
            var reList = ViewBag.REs as List<Group16_iPERMITAPP.Models.RE>;
        }

        @if (reList != null && reList.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>RE ID</th>
                        <th>Contact Person</th>
                        <th>Email</th>
                        <th>Organization</th>
                        <th>Address</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var re in reList)
                    {
                        <tr>
                            <td>@re.REId</td>
                            <td>@re.ContactPersonName</td>
                            <td>
                                @if (!string.IsNullOrEmpty(re.REEmail))
                                {
                                    <a href="mailto:@re.REEmail">@re.REEmail</a>
                                }
                            </td>
                            <td>@re.OrganizationName</td>
                            <td>@re.OrganizationAddress</td>
                            <td>@re.CreatedDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="muted">No registered entities found.</div>
        }
    </div>
</body>
</html>