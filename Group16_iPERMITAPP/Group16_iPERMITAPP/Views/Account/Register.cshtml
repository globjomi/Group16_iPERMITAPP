@{
    Layout = null;
    ViewBag.Title = "Register";
}

<!DOCTYPE html>
<html>
<head>
    <title>iPERMIT - Create Account</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f0f4f8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 40px 0;
        }

        .register-container {
            background-color: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 450px;
        }

            .register-container h1 {
                text-align: center;
                color: #2c7a4b;
                margin-bottom: 10px;
                font-size: 28px;
            }

            .register-container p.subtitle {
                text-align: center;
                color: #888;
                margin-bottom: 30px;
                font-size: 14px;
            }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                margin-bottom: 6px;
                color: #555;
                font-size: 14px;
                font-weight: 600;
            }

            .form-group input {
                width: 100%;
                padding: 10px 14px;
                border: 1px solid #ddd;
                border-radius: 8px;
                font-size: 14px;
                outline: none;
                transition: border 0.3s;
            }

                .form-group input:focus {
                    border-color: #2c7a4b;
                }

        .btn-register {
            width: 100%;
            padding: 12px;
            background-color: #2c7a4b;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s;
        }

            .btn-register:hover {
                background-color: #245f3c;
            }

        .error-message {
            background-color: #ffe0e0;
            color: #cc0000;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            text-align: center;
        }

        .login-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #888;
        }

            .login-link a {
                color: #2c7a4b;
                text-decoration: none;
                font-weight: 600;
            }

                .login-link a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="register-container">
        <h1>🌿 iPERMIT</h1>
        <p class="subtitle">Create a new RE Account</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-message">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
        {
            <div class="form-group">
                <label>RE ID</label>
                <input type="text" name="REId" placeholder="Enter your RE ID" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="REPassword" placeholder="Enter your password" />
            </div>
            <div class="form-group">
                <label>Contact Person Name</label>
                <input type="text" name="ContactPersonName" placeholder="Enter contact person name" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="REEmail" placeholder="Enter your email" />
            </div>
            <div class="form-group">
                <label>Organization Name</label>
                <input type="text" name="OrganizationName" placeholder="Enter organization name" />
            </div>
            <div class="form-group">
                <label>Organization Address</label>
                <input type="text" name="OrganizationAddress" placeholder="Enter organization address" />
            </div>
            <input type="submit" class="btn-register" value="Create Account" />
        }

        <div class="login-link">
            Already have an account? <a href="@Url.Action("Login", "Account")">Login here</a>
        </div>
    </div>
</body>
</html>